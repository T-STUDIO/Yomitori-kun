import React, { useRef, useState } from 'react';

const ReceiptScanner = () => {
  const videoRef = useRef<HTMLVideoElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const [amount, setAmount] = useState<string>("");
  const [loading, setLoading] = useState(false);

  // カメラを起動
  const startCamera = async () => {
    const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    if (videoRef.current) videoRef.current.srcObject = stream;
  };

  // 撮影とOCR処理
  const captureAndOCR = async () => {
    if (!canvasRef.current || !videoRef.current) return;
    setLoading(true);

    const context = canvasRef.current.getContext('2d');
    context?.drawImage(videoRef.current, 0, 0, 640, 480);
    const base64Image = canvasRef.current.toDataURL('image/jpeg').split(',')[1];

    // Google Cloud Vision API へのリクエスト（APIキーが必要）
    const apiKey = 'YOUR_GOOGLE_CLOUD_VISION_API_KEY';
    const response = await fetch(`https://vision.googleapis.com/v1/images:annotate?key=${apiKey}`, {
      method: 'POST',
      body: JSON.stringify({
        requests: [{
          image: { content: base64Image },
          features: [{ type: 'TEXT_DETECTION' }]
        }]
      })
    });

    const result = await response.json();
    const fullText = result.responses[0]?.fullTextAnnotation?.text || "";
    
    // 合計金額を抽出する簡易ロジック（正規表現）
    const match = fullText.match(/(合計|小計|Total)\D*(\d{1,3}(,\d{3})*)/i);
    if (match) {
      setAmount(match[2].replace(/,/g, ''));
    } else {
      alert("金額が見つかりませんでした。");
    }
    setLoading(false);
  };

  // スプレッドシートへ送信
  const sendToSheet = async () => {
    const gasUrl = 'YOUR_GAS_WEB_APP_URL';
    await fetch(gasUrl, {
      method: 'POST',
      body: JSON.stringify({ amount: parseInt(amount) }),
    });
    alert("スプレッドシートに記録しました！");
    setAmount("");
  };

  return (
    <div style={{ padding: '20px', textAlign: 'center' }}>
      <h2>レシートスキャナー</h2>
      <video ref={videoRef} autoPlay playsInline style={{ width: '100%', maxWidth: '400px', borderRadius: '8px' }} />
      <canvas ref={canvasRef} width="640" height="480" style={{ display: 'none' }} />
      
      <div style={{ marginTop: '20px' }}>
        <button onClick={startCamera}>カメラ起動</button>
        <button onClick={captureAndOCR} disabled={loading} style={{ marginLeft: '10px' }}>
          {loading ? '解析中...' : '撮影して解析'}
        </button>
      </div>

      {amount && (
        <div style={{ marginTop: '20px', border: '1px solid #ccc', padding: '10px' }}>
          <p>抽出金額: <strong>¥{amount}</strong></p>
          <button onClick={sendToSheet} style={{ backgroundColor: '#4CAF50', color: 'white' }}>確定して送信</button>
        </div>
      )}
    </div>
  );
};

export default ReceiptScanner;
